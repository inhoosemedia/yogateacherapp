# Database (Neon Postgres) — REQUIRED
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Better Auth — REQUIRED
# Generate a fresh secret per environment:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=

# These two MUST match the deployed domain (no trailing slash).
# Locally:  http://localhost:3000
# On Vercel: https://<your-project>.vercel.app  (or your custom domain)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional Google OAuth (leave empty if not using)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
