# Database (Neon Postgres) — REQUIRED
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Better Auth — REQUIRED
# Generate a fresh secret per environment:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=

# These two MUST match the deployed domain (no trailing slash).
# Locally:  http://localhost:3000
# On Vercel: https://<your-project>.vercel.app  (or your custom domain)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional Google OAuth (leave empty if not using)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Resend — transactional email
# Sign up free at https://resend.com (3,000 emails/month, no card)
RESEND_API_KEY=
# Until your domain is verified in Resend, use the onboarding sender:
#   YogaTeacher <onboarding@resend.dev>
# After verifying yogateacherapp.com (or your domain), change to e.g.:
#   YogaTeacher <hello@yogateacherapp.com>
RESEND_FROM_EMAIL=YogaTeacher <onboarding@resend.dev>

# Cron — bearer token Vercel Cron / external schedulers must send.
CRON_SECRET=

# Razorpay subscriptions (platform billing — studios pay you)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_PLAN_STUDIO=plan_xxx
# RAZORPAY_PLAN_MULTI=plan_xxx
# RAZORPAY_WEBHOOK_SECRET=
